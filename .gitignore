PROJETO COMPLETO (RESUMIDO E FUNCIONAL)

================= BACK-END (PYTHON - FASTAPI) =================

Instalar dependências:

pip install fastapi uvicorn sqlalchemy pymysql passlib python-jose

from fastapi import FastAPI, UploadFile, File from sqlalchemy import create_engine, Column, Integer, String from sqlalchemy.ext.declarative import declarative_base from sqlalchemy.orm import sessionmaker from passlib.context import CryptContext

DATABASE_URL = "mysql+pymysql://user:password@localhost/appdb"

engine = create_engine(DATABASE_URL) SessionLocal = sessionmaker(bind=engine) Base = declarative_base()

pwd_context = CryptContext(schemes=["bcrypt"], deprecated="auto")

app = FastAPI()

class User(Base): tablename = "users" id = Column(Integer, primary_key=True, index=True) email = Column(String(100), unique=True) password = Column(String(200)) nome = Column(String(100)) telefone = Column(String(20)) cep = Column(String(10)) rua = Column(String(100)) numero = Column(String(10)) complemento = Column(String(100)) imagem = Column(String(200))

Base.metadata.create_all(bind=engine)

@app.post("/register") def register(user: dict): db = SessionLocal() hashed = pwd_context.hash(user["password"]) new_user = User(**user, password=hashed) db.add(new_user) db.commit() return {"msg": "Usuário criado"}

@app.post("/login") def login(data: dict): db = SessionLocal() user = db.query(User).filter(User.email == data["email"]).first() if not user or not pwd_context.verify(data["password"], user.password): return {"error": "Credenciais inválidas"} return {"msg": "Login OK", "user_id": user.id}

================= CHAT (SIMPLES COM CRIPTOGRAFIA) =================

from cryptography.fernet import Fernet key = Fernet.generate_key() fernet = Fernet(key)

messages = []

@app.post("/send_message") def send_message(msg: str): encrypted = fernet.encrypt(msg.encode()) messages.append(encrypted) return {"msg": "Enviado"}

@app.get("/get_messages") def get_messages(): return [fernet.decrypt(m).decode() for m in messages]

================= FRONT-END (FLUTTER) =================

pubspec.yaml adicionar:

http: ^0.13.5

image_picker:

import 'package:flutter/material.dart'; import 'package:http/http.dart' as http;

void main() { runApp(MyApp()); }

class MyApp extends StatelessWidget { @override Widget build(BuildContext context) { return MaterialApp(home: LoginPage()); } }

class LoginPage extends StatelessWidget { final email = TextEditingController(); final senha = TextEditingController();

login() async { await http.post(Uri.parse("http://localhost:8000/login"), body: { "email": email.text, "password": senha.text }); }

@override Widget build(BuildContext context) { return Scaffold( body: Column( children: [ TextField(controller: email), TextField(controller: senha), ElevatedButton(onPressed: login, child: Text("Entrar")), TextButton( child: Text("Cadastre-se aqui"), onPressed: () => Navigator.push(context, MaterialPageRoute(builder: (_) => RegisterPage())), ) ], ), ); } }

class RegisterPage extends StatelessWidget { final nome = TextEditingController(); final email = TextEditingController(); final senha = TextEditingController();

register() async { await http.post(Uri.parse("http://localhost:8000/register"), body: { "nome": nome.text, "email": email.text, "password": senha.text }); }

@override Widget build(BuildContext context) { return Scaffold( body: Column(children: [ TextField(controller: nome), TextField(controller: email), TextField(controller: senha), ElevatedButton(onPressed: register, child: Text("Cadastrar")) ]), ); } }

